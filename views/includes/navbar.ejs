<style>
/* ---------- Search Button ---------- */
.search-btn {
  background-color: #fe424d;
  color: white;
  border-radius: 25px;
  padding: 0 1rem;
  transition: 0.3s;
}

.search-btn:hover {
  background-color: #d9363e;
  color: white;
}

/* ---------- Search Input ---------- */
.search-inp {
  border-radius: 25px;
  font-size: 0.9rem;
}

/* ---------- Navbar Brand Icon ---------- */
.navbar-brand i {
  font-size: 1.2rem;
  margin-right: 5px;
}
</style>

<nav class="navbar navbar-expand-md navbar-light bg-light border-bottom sticky-top">
  <div class="container-fluid">
    <!-- Logo / Home -->
    <a class="navbar-brand d-flex align-items-center" href="/listings">
      <i class="fa-regular fa-compass"></i> SafeStays
    </a>

    <!-- Toggler for mobile -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar links -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/listings/new">Create a New Listing </a>
        </li>
      </ul>

      <!-- Search Bar -->
      <form class="d-flex me-3" role="search">
        <input class="form-control me-2 search-inp" type="search" placeholder="Search destination" />
        <button class="btn search-btn" type="submit">
          <i class="fa-solid fa-magnifying-glass me-1"></i> Search
        </button>
      </form>

      <!-- Auth Links -->
      <ul class="navbar-nav">
        <% if (!currUser) { %>
          <li class="nav-item"><a class="nav-link fw-bold" href="/signup">Sign up</a></li>
          <li class="nav-item"><a class="nav-link fw-bold" href="/login">Log in</a></li>
        <% } %>
        <% if (currUser) { %>
          <li class="nav-item"><a class="nav-link fw-bold" href="/logout">Log Out</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>